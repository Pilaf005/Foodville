# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files — all three stay local for now (see README "Environment files").
# .env.example is a placeholder-only template and is safe to commit later,
# but is held back until it's been reviewed.
.env*

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts
